PORT=8787
JWT_SECRET=change-me-in-production
DATA_DIR=./data
# лимит облачного аудио на пользователя (байты), 500 МБ
AUDIO_QUOTA_BYTES=524288000
# CORS: origins через запятую; пусто = разрешить все (удобно для Tauri dev)
ALLOWED_ORIGINS=
# пользовательские визуализаторы (.tsx)
USER_VIZ_MAX_BYTES=524288
USER_VIZ_MAX_ITEMS=24

# Письма (сброс пароля). Без SMTP в dev код пишется в консоль сервера.
APP_NAME=Loomi
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM=Loomi <noreply@example.com>
